[user]
	email = {{ .email }}
	name = {{ .name }}

[http]
	postBuffer = 157286400

[color]
	ui = true

[core]
{{ if lookPath "nvim" }}
    editor = nvim
{{ else }}
    editor = vim
{{ end }}
{{ if lookPath "delta" }}
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true
    line-numbers = true
    hyperlinks = true

[merge]
    conflictStyle = zdiff3
{{ end }}

