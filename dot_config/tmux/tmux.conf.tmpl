
# Enable 256-color and true-color (24-bit) support in tmux
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",xterm-256color:Tc"

# Fix titlebar
set -g set-titles on
set -g set-titles-string "#T"

# Good indexing
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on

# Avoid ESC delay
set -s escape-time 0

# General
set -g status-justify left
setw -g aggressive-resize on
set -g set-clipboard on
set -g detach-on-destroy off
set -g history-limit 1000000
set -g display-time 3000
set -g mouse on
set -g status-interval 20
set -g allow-passthrough on
set -s extended-keys on
set -as terminal-features 'ghostty:extkeys'
set-option -g focus-events on

# Set prefix key
unbind C-b
set -g prefix C-Space
bind C-Space send-prefix

bind r source-file ~/.config/tmux/tmux.conf\; display "Config reloaded!"

unbind %
unbind \"

bind-key w switch-client -T window-mgr
bind-key -T window-mgr v split-window -h -c "#{pane_current_path}"
bind-key -T window-mgr h split-window -v -c "#{pane_current_path}"
bind-key -T window-mgr w choose-window
bind-key -T window-mgr q kill-pane

bind c new-window -c "#{pane_current_path}"
bind q kill-window
bind d detach-client
bind Q confirm-before -p "Kill entire session? (y/n)" kill-session
bind v copy-mode

bind -r j select-pane -D
bind -r k select-pane -U
bind -r l select-pane -R
bind -r h select-pane -L

bind -r J resize-pane -D 3
bind -r K resize-pane -U 3
bind -r L resize-pane -R 5
bind -r H resize-pane -L 5

bind -r m resize-pane -Z

# Enable vi mode to allow us to use vim keys to move around in copy mode (Prefix + [ places us in copy mode)
set-window-option -g mode-keys vi

bind -T copy-mode-vi 'v' send -X begin-selection
bind -T copy-mode-vi 'y' send-keys -X copy-pipe-and-cancel "cb-copy"
bind p run "wl-paste -n | tmux load-buffer - ; tmux paste-buffer"

bind -n MouseDrag1Pane { if -F '#{||:#{pane_in_mode},#{mouse_any_flag}}' { send -M } { copy-mode -M } }
unbind -T copy-mode-vi MouseDragEnd1Pane

# tpm plugin manager
set -g @plugin 'tmux-plugins/tpm'

# List of tmux plugins
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @plugin 'tmux-plugins/tmux-open'
set -g @plugin 'hendrikmi/tmux-cpu-mem-monitor'

# Style
fg="color6"
act_bg="color8"
act_fg="color15"
highlight_color="color2"
border="color8"
act_border="color5"

set -g status-position top
set -g status-left-length 160
set -g pane-border-lines "heavy"
set -g pane-border-indicators "off"
set -g status-style "fg=${fg},bg=default"
set -g status-left "#[fg=${fg}]  #S    #h    "
set -g status-right " #{cpu}     #{mem} "
set -g window-status-current-format "#[fg=${act_fg},bg=#{act_bg},bold]  #I:#W#{?window_zoomed_flag, 󰍋 , }"
set -g window-status-format "   #I:#W "
set -g message-style "fg=${act_fg},bg=${highlight_color},bold"
set -g mode-style "fg=${act_fg},bg=${highlight_color}"
set -g pane-border-style "fg=${border}"
set -g pane-active-border-style "fg=${act_border}"

# Resurrect
set -g @resurrect-capture-pane-contents 'on'
set -g @resurrect-dir '~/.local/share/tmux/resurrect'
set -g @continuum-restore 'on'
set -g @continuum-save-interval '10'

# vim integration
{{ if lookPath "nvim" }}
set -g @plugin 'mrjones2014/smart-splits.nvim'
set -g @smart-splits_no_wrap 'no'

bind C-l send-keys 'C-l'
bind C-k send-keys 'C-k'
bind C-j send-keys 'C-j'
bind C-h send-keys 'C-h'

bind M-l send-keys 'M-l'
bind M-k send-keys 'M-k'
bind M-j send-keys 'M-j'
bind M-h send-keys 'M-h'


{{ else }}
set -g @plugin 'christoomey/vim-tmux-navigator'

{{ end }}

set-environment -g TMUX_PLUGIN_MANAGER_PATH '~/.local/share/tmux/plugins'

# Initialize TMUX plugin manager (keep this line at the very bottom of tmux.conf)
run '~/.local/share/tmux/tpm/tpm'
