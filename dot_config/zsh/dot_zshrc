
[ -d $ZSH_CACHE ] || mkdir -p $ZSH_CACHE

# Load helper functions
for f in $ZDOTDIR/functions/*.zsh; do
    source $f
done

_zplugindir=$ZSH_CACHE/plugins
_zcompletions=$ZSH_CACHE/completions

# Necessary for completion generator
GENCOMPL_FPATH=$_zcompletions
ZSH_COMPDUMP=$_zcompletions/zcompdump
FAST_WORK_DIR=$_zplugindir/fast-syntax-highlighting/custom_theme

plugins=(
    "zsh-users/zsh-autosuggestions"
    "zdharma-continuum/fast-syntax-highlighting"
    "RobSis/zsh-completion-generator"
    "romkatv/zsh-defer"
    
    # Lazy load
    "zsh-users/zsh-completions"
)

# Automatically update every 7 days
plugin-update 7
plugin-load $plugins

# Load prompt
source $ZDOTDIR/prompt.zsh

# Setting up fast syntax highlight theme
fast-theme-generate

ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=8,bold,italic'

#(( ${+ZSH_HIGHLIGHT_STYLES} )) || typeset -A ZSH_HIGHLIGHT_STYLES
#ZSH_HIGHLIGHT_STYLES[path]='fg=white'

fpath=($_zplugindir/zsh-completions/src $fpath)

# History setup
HISTFILE=$ZSH_CACHE/zsh_history
HISTSIZE=50000
SAVEHIST=$HISTSIZE
HISTDUP=erase
ZCALC_HISTFILE=$ZSH_CACHE/zcalc_history

setopt appendhistory
setopt hist_find_no_dups
setopt hist_ignore_dups
setopt hist_ignore_space
setopt hist_reduce_blanks
setopt inc_append_history
setopt hist_save_no_dups
setopt sharehistory

setopt autocd
setopt extendedglob
setopt always_to_end
setopt auto_param_slash
setopt auto_menu
setopt auto_list
setopt complete_in_word

unsetopt menu_complete
unsetopt flow_control
unsetopt beep
unsetopt notify

if command -v dirname >/dev/null 2>&1; then
    eval $(dircolors -b)
else
    LS_COLORS='no=00:fi=00:di=01;34:ln=01;36:pi=40;33:so=01;35:bd=40;33;01:cd=40;33;01:or=40;31;01:ex=01;32'
fi

zstyle ':completion:*:default' menu select=2
zstyle ':completion:*' complete-options true
zstyle ':completion:*' matcher-list '' 'm:{a-zA-Z}={A-Za-z}' 'r:|[._-]=* r:|=*' 'l:|=* r:|=*'
zstyle ':completion::complete:*' use-cache on
zstyle ':completion::complete:*' cache-path $_zcompletions/compcache
zstyle :plugin:zsh-completion-generator programs cat
zstyle ':completion:*:default' list-colors "${(s.:.)LS_COLORS}"'ma=1;100;97'
zstyle ':completion:*:descriptions' format '%B%F{blue}── %d ──%f%b'
zstyle ':completion:*:*:*:*:corrections' format '%F{yellow}!- %d (errors: %e) -!%f'
zstyle ':completion:*:messages' format ' %F{magenta} -- %d --%f'
zstyle ':completion:*:warnings' format ' %F{red}-- no matches found --%f'
zstyle ':completion:*:default' list-prompt '%B%F{green}Page %p%f%b'
zstyle ':completion:*' group-name ''
zstyle ':completion:*:*:-command-:*:*' group-order aliases commands functions builtins 
zstyle ':completion:*:*:cd:*' tag-order local-directories directory-stack path-directories
zstyle ':completion:*' keep-prefix true
zstyle -e ':completion:*:(ssh|scp|sftp|rsh|rsync):hosts' hosts 'reply=(${=${${(f)"$(cat {/etc/ssh_,~/.ssh/known_}hosts(|2)(N) /dev/null)"}%%[# ]*}//,/ })'


#zle_highlight=(
#  'region:bg=235,fg=220'
#  'special:fg=98'
#  'suffix:fg=58'
#  'isearch:fg=202,bg=235,bold'
#  'paste:fg=230'
#)

autoload -Uz zcalc
autoload -Uz zmv
autoload -Uz zln
autoload -Uz zcp
autoload -Uz up-line-or-beginning-search
autoload -Uz down-line-or-beginning-search
autoload -Uz compinit && compinit -d $ZSH_COMPDUMP
autoload edit-command-line

zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
zle -N expand-alias
zle -N edit-command-line

bindkey -e

bindkey -M main "^[[A" up-line-or-beginning-search
bindkey -M main "^[[B" down-line-or-beginning-search
bindkey -M main "^[OA" up-line-or-beginning-search
bindkey -M main "^[OB" down-line-or-beginning-search
bindkey -M main ' ' expand-alias
bindkey '^v' edit-command-line

export FZF_DEFAULT_OPTS="
  --color=16 
  --height=50% 
  --layout=reverse 
  --info=inline 
  --margin=1 
  --tmux top,40% 
  --bind 'ctrl-y:execute-silent(printf {} | cut -f 2- | wl-copy --trim-newline)'"
export FZF_DEFAULT_COMMAND='fd --type f --strip-cwd-prefix --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

export FZF_CTRL_T_OPTS="
  --walker-skip .git
  --preview 'bat -n --color=always --line-range :500 {}'
  --bind 'ctrl-/:change-preview-window(down|hidden|)'"

export FZF_ALT_C_OPTS="
  --walker-skip .git,node_modules,target
  --preview 'tree -C {}'"

export _ZO_EXCLUDE_DIRS="/etc:/var:/usr"

if command -v fzf >/dev/null 2>&1; then
    source <(fzf --zsh)
fi
if command -v zoxide >/dev/null 2>&1; then
    eval "$(zoxide init --cmd cd zsh)"
fi


source $ZDOTDIR/aliases.zsh
source $ZDOTDIR/newt_settings.zsh
